rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "ueca095eca780ed9b88@dkumed26.com";
    }

    function isApproved() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == "approved";
    }

    function canUseSite() {
      return isAdmin() || (isApproved() && initialPasswordChangeComplete());
    }

    function initialPasswordChangeComplete() {
      return !exists(/databases/$(database)/documents/initialPasswordSetup/$(request.auth.uid))
        || get(/databases/$(database)/documents/initialPasswordSetup/$(request.auth.uid)).data.required != true;
    }

    function validOptionalGameScore(data, field) {
      return !data.keys().hasAny([field])
        || (data[field] is number
          && data[field] >= 0
          && data[field] <= data.bestLaps);
    }

    function nondecreasingGameScore(nextData, previousData, field) {
      return validOptionalGameScore(nextData, field)
        && (!previousData.keys().hasAny([field])
          || nextData[field] >= previousData[field]);
    }

    match /users/{uid} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == uid);
      allow create, update, delete: if isAdmin();
    }

    match /initialPasswordSetup/{uid} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == uid);
      allow create, update: if (isAdmin() || isApproved())
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'uid', 'email', 'required', 'formConfirmed', 'triggeredAt', 'completedAt'
        ])
        && request.resource.data.keys().hasAll([
          'uid', 'email', 'required', 'formConfirmed'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.required is bool
        && request.resource.data.formConfirmed is bool;
      allow delete: if isAdmin();
    }

    match /photos/{photoId} {
      allow read, create: if canUseSite();
      allow delete: if isAdmin()
        || (isApproved() && request.auth.uid == resource.data.uid);
      allow update: if false;
    }

    match /calendarEvents/{eventId} {
      allow read: if canUseSite();
      allow create, update, delete: if isAdmin();
    }

    match /calendarPersonal/{uid}/events/{eventId} {
      allow read, create, update, delete: if canUseSite()
        && request.auth.uid == uid;
    }

    match /members/{memberId} {
      allow read: if canUseSite();
      allow create, update, delete: if isAdmin();
    }

    match /submissionChecklists/{checklistId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /submissionAlerts/{alertId} {
      allow read: if isAdmin()
        || (isApproved()
          && request.auth.token.email == resource.data.recipientEmail);
      allow create, update, delete: if isAdmin();
    }

    match /notices/{noticeId} {
      allow read: if canUseSite();
      allow create, update, delete: if isAdmin();
    }

    match /alerts/{alertId} {
      allow read: if canUseSite();
      allow create, update, delete: if isAdmin();
    }

    match /passwordChangeEvents/{eventId} {
      allow read, delete: if isAdmin();
      allow update: if false;
      allow create: if (isAdmin() || isApproved())
        && request.resource.data.keys().hasOnly([
          'uid', 'email', 'changedAt', 'type', 'changedBy'
        ])
        && request.resource.data.keys().hasAll([
          'uid', 'email', 'changedAt', 'type', 'changedBy'
        ])
        && request.resource.data.changedAt == request.time
        && request.resource.data.changedBy == request.auth.token.email
        && (
          (request.resource.data.type == 'selfChange'
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.email == request.auth.token.email)
          || (isAdmin() && request.resource.data.type == 'adminReset')
        );
    }

    match /timetableGlobal/{entryId} {
      allow read: if canUseSite();
      allow create, update, delete: if isAdmin();
    }

    match /timetablePersonal/{uid}/entries/{entryId} {
      allow read, create, update, delete: if canUseSite()
        && request.auth.uid == uid;
    }

    match /polls/{pollId} {
      function poll() {
        return get(/databases/$(database)/documents/polls/$(pollId)).data;
      }

      function isPollOwner() {
        return request.auth != null && poll().creatorUid == request.auth.uid;
      }

      allow read: if canUseSite();
      allow create: if canUseSite()
        && request.resource.data.creatorUid == request.auth.uid;
      allow update: if isAdmin() || isPollOwner()
        || (isApproved()
          && resource.data.closed == false
          && resource.data.allowOptionAdd == true
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['options', 'updatedAt']));
      allow delete: if isAdmin() || isPollOwner();

      match /votes/{uid} {
        allow read: if canUseSite()
          && (isAdmin()
            || request.auth.uid == uid
            || isPollOwner()
            || poll().closed == true
            || poll().showResultsBeforeClose == true);
        allow create: if canUseSite()
          && request.auth.uid == uid
          && poll().closed == false;
        allow update: if canUseSite()
          && request.auth.uid == uid
          && poll().closed == false
          && poll().allowVoteChange == true;
        allow delete: if canUseSite()
          && (isAdmin() || isPollOwner() || request.auth.uid == uid);
      }

      match /voters/{uid} {
        allow read: if canUseSite()
          && (isAdmin() || isPollOwner() || request.auth.uid == uid);
        allow create, update: if canUseSite()
          && request.auth.uid == uid
          && poll().closed == false;
        allow delete: if canUseSite()
          && (isAdmin() || isPollOwner() || request.auth.uid == uid);
      }
    }

    // 천호지 달리기: 실명 기록은 본인과 관리자만, 점수판은 승인된 사용자만 읽습니다.
    match /gameScores/{uid} {
      allow read: if isAdmin()
        || (canUseSite() && request.auth.uid == uid);
      allow create: if canUseSite()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'uid', 'email', 'name', 'bestLaps',
          'otterBestLaps', 'turtleBestLaps',
          'otterMobileBestLaps', 'otterPcBestLaps',
          'turtleMobileBestLaps', 'turtlePcBestLaps',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'uid', 'email', 'name', 'bestLaps', 'updatedAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 20
        && request.resource.data.bestLaps is number
        && request.resource.data.bestLaps >= 0
        && request.resource.data.bestLaps <= 10000
        && request.resource.data.keys().hasAny([
          'otterMobileBestLaps', 'otterPcBestLaps',
          'turtleMobileBestLaps', 'turtlePcBestLaps'
        ])
        && validOptionalGameScore(request.resource.data, 'otterBestLaps')
        && validOptionalGameScore(request.resource.data, 'turtleBestLaps')
        && validOptionalGameScore(request.resource.data, 'otterMobileBestLaps')
        && validOptionalGameScore(request.resource.data, 'otterPcBestLaps')
        && validOptionalGameScore(request.resource.data, 'turtleMobileBestLaps')
        && validOptionalGameScore(request.resource.data, 'turtlePcBestLaps')
        && request.resource.data.updatedAt == request.time;
      allow update: if canUseSite()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'uid', 'email', 'name', 'bestLaps',
          'otterBestLaps', 'turtleBestLaps',
          'otterMobileBestLaps', 'otterPcBestLaps',
          'turtleMobileBestLaps', 'turtlePcBestLaps',
          'updatedAt'
        ])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.name == resource.data.name
        && request.resource.data.bestLaps is number
        && request.resource.data.bestLaps >= resource.data.bestLaps
        && request.resource.data.bestLaps <= 10000
        && nondecreasingGameScore(request.resource.data, resource.data, 'otterBestLaps')
        && nondecreasingGameScore(request.resource.data, resource.data, 'turtleBestLaps')
        && nondecreasingGameScore(request.resource.data, resource.data, 'otterMobileBestLaps')
        && nondecreasingGameScore(request.resource.data, resource.data, 'otterPcBestLaps')
        && nondecreasingGameScore(request.resource.data, resource.data, 'turtleMobileBestLaps')
        && nondecreasingGameScore(request.resource.data, resource.data, 'turtlePcBestLaps')
        && request.resource.data.updatedAt == request.time;
      allow delete: if isAdmin();
    }

    match /gameLeaderboard/{uid} {
      allow read: if canUseSite();
      allow create: if canUseSite()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'bestLaps', 'otterBestLaps', 'turtleBestLaps',
          'otterMobileBestLaps', 'otterPcBestLaps',
          'turtleMobileBestLaps', 'turtlePcBestLaps',
          'isAdmin', 'updatedAt'
        ])
        && request.resource.data.keys().hasAll(['bestLaps', 'isAdmin', 'updatedAt'])
        && request.resource.data.isAdmin == isAdmin()
        && request.resource.data.bestLaps is number
        && request.resource.data.bestLaps >= 0
        && request.resource.data.bestLaps <= 10000
        && request.resource.data.keys().hasAny([
          'otterMobileBestLaps', 'otterPcBestLaps',
          'turtleMobileBestLaps', 'turtlePcBestLaps'
        ])
        && validOptionalGameScore(request.resource.data, 'otterBestLaps')
        && validOptionalGameScore(request.resource.data, 'turtleBestLaps')
        && validOptionalGameScore(request.resource.data, 'otterMobileBestLaps')
        && validOptionalGameScore(request.resource.data, 'otterPcBestLaps')
        && validOptionalGameScore(request.resource.data, 'turtleMobileBestLaps')
        && validOptionalGameScore(request.resource.data, 'turtlePcBestLaps')
        && request.resource.data.updatedAt == request.time;
      allow update: if canUseSite()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'bestLaps', 'otterBestLaps', 'turtleBestLaps',
          'otterMobileBestLaps', 'otterPcBestLaps',
          'turtleMobileBestLaps', 'turtlePcBestLaps',
          'isAdmin', 'updatedAt'
        ])
        && request.resource.data.isAdmin == isAdmin()
        && request.resource.data.bestLaps is number
        && request.resource.data.bestLaps >= resource.data.bestLaps
        && request.resource.data.bestLaps <= 10000
        && nondecreasingGameScore(request.resource.data, resource.data, 'otterBestLaps')
        && nondecreasingGameScore(request.resource.data, resource.data, 'turtleBestLaps')
        && nondecreasingGameScore(request.resource.data, resource.data, 'otterMobileBestLaps')
        && nondecreasingGameScore(request.resource.data, resource.data, 'otterPcBestLaps')
        && nondecreasingGameScore(request.resource.data, resource.data, 'turtleMobileBestLaps')
        && nondecreasingGameScore(request.resource.data, resource.data, 'turtlePcBestLaps')
        && request.resource.data.updatedAt == request.time;
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
